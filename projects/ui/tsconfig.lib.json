/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/lib",
    "declaration": true,
    "declarationMap": true,
    "types": []
  },
  "include": ["src/**/*.ts"],
  // Stories are documentation, not shippable API — they must never reach the
  // ng-packagr output or drag @storybook/* into the library's dependencies.
  // (.storybook/tsconfig.json re-includes them for the Storybook build.)
  "exclude": ["**/*.spec.ts", "**/*.stories.ts"]
}
