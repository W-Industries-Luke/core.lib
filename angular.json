{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "ui": {
      "projectType": "library",
      "root": "projects/ui",
      "sourceRoot": "projects/ui/src",
      "prefix": "ui",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ui/tsconfig.spec.json",
            "coverage": true,
            "coverageInclude": ["projects/ui/src/**/*.ts"],
            "coverageExclude": [
              "projects/ui/src/**/*.spec.ts",
              "projects/ui/src/**/*.stories.ts",
              "projects/ui/src/**/index.ts",
              "projects/ui/src/public-api.ts",
              "projects/ui/src/styles/token-swatches.ts"
            ],
            "coverageReporters": ["text-summary", "text", "html", "json-summary"],
            "coverageThresholds": {
              "statements": 90,
              "branches": 92,
              "functions": 80,
              "lines": 94
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/ui/**/*.ts", "projects/ui/**/*.html"]
          }
        },
        "storybook": {
          "builder": "@storybook/angular-vite:start-storybook",
          "options": {
            "configDir": "projects/ui/.storybook",
            "styles": ["./.storybook/preview.scss"],
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular-vite:build-storybook",
          "options": {
            "configDir": "projects/ui/.storybook",
            "styles": ["./.storybook/preview.scss"],
            "outputDir": "storybook-static"
          }
        }
      }
    }
  }
}
